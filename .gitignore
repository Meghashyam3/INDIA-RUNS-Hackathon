# ── Python bytecode & caches ──────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python

# ── Virtual environment ────────────────────────────────────────
.venv*/
venv*/
env/


# ── Large dataset files (download from hackathon bundle) ───────
