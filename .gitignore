# The final CSV is generated by rank.py — not checked in
team_*.csv
submission.csv

# ── Jupyter notebook checkpoints ──────────────────────────────
.ipynb_checkpoints/

# ── OS cruft ──────────────────────────────────────────────────
.DS_Store
__MACOSX/
Thumbs.db

# ── IDE configs ───────────────────────────────────────────────
.vscode/
.idea/
*.swp
